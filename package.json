{
  "name": "claw-vault",
  "version": "0.1.0",
  "description": "HashiCorp Vault SecretRef provider integration for OpenClaw",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sallyom/claw-vault.git"
  },
  "files": [
    "README.md",
    "openclaw.plugin.json",
    "index.ts",
    "vault-secret-ref-resolver.js"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.6"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.5.6"
    },
    "install": {
      "clawhubSpec": "claw-vault",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.6"
    },
    "release": {
      "publishToClawHub": true
    }
  }
}
