{
  "name": "claw-vault",
  "version": "0.1.0",
  "description": "HashiCorp Vault SecretRef provider integration for OpenClaw",
  "type": "module",
  "packageManager": "npm@11.4.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sallyom/claw-vault.git"
  },
  "homepage": "https://github.com/sallyom/claw-vault#readme",
  "bugs": {
    "url": "https://github.com/sallyom/claw-vault/issues"
  },
  "files": [
    "README.md",
    "LICENSE",
    "openclaw.plugin.json",
    "index.ts",
    "cli-metadata.ts",
    "cli.ts",
    "vault-secret-ref-resolver.js",
    "dist"
  ],
  "scripts": {
    "build": "tsc --outDir dist --rootDir . --module NodeNext --moduleResolution NodeNext --target ES2022 --strict --skipLibCheck --types node --declaration false --sourceMap false index.ts cli.ts cli-metadata.ts && cp vault-secret-ref-resolver.js dist/vault-secret-ref-resolver.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "commander": "14.0.2",
    "openclaw": "2026.5.12",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.6"
    },
    "install": {
      "clawhubSpec": "claw-vault",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.6"
    },
    "release": {
      "publishToClawHub": true
    }
  }
}
